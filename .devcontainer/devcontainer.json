{
  "name": "indecomposables",
  "build": {
      "dockerfile": "Dockerfile"
  },
  "postCreateCommand": "/bin/bash .devcontainer/setup.sh",
  "postAttachCommand": {
    "server": "./compute_indecomposables.sh"
  },
  "customizations": {
    "codespaces": {
      "openFiles": ["README.md"]
    },
    "vscode": {
      "extensions": [
        "Lov3.sagemath-enhanced",
        "ms-python.python"
      ],
      "settings": {
        "python.defaultInterpreterPath": "sage --python"
      }
    }
  }
}
